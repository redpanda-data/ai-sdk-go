# Environment variables for development and testing
# Copy this file to .env.local and fill in your actual values

# OpenAI API Key (required for integration tests)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Context7 API Key (required for MCP Context7 integration tests)
# Get your API key from: https://context7.com
CONTEXT7_API_KEY=your-context7-key-here
